# ══════════════════════════════════════════════════════
#  RMS — .gitignore
# ══════════════════════════════════════════════════════

# ── СЕКРЕТЫ — НИКОГДА не коммитить ───────────────────
.env
*.env
!.env.example
*token.json*
*credentials.json*

# ── Базы данных ───────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/

# ── Node / Frontend ───────────────────────────────────
node_modules/
frontend/node_modules/
frontend/build/
frontend/dist/
.pnp
.pnp.js

# ── Логи ─────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE ───────────────────────────────────────────────
.idea/
.vscode/
*.swp

# ── Системные ─────────────────────────────────────────
.DS_Store
*.pem

# ── Тесты ─────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── Архивы / сборки ───────────────────────────────────
*.zip
*.tar.gz
dist/
build/
.cache/