
DATABASE_URL=sqlite+aiosqlite:///./rms.db

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

SMTP_SERVER=smtp.yandex.ru
SMTP_PORT=465
SMTP_USERNAME=your_email@yandex.ru
SMTP_PASSWORD=REPLACE_WITH_YANDEX_APP_PASSWORD_16_CHARS
SMTP_FROM=your_email@yandex.ru
SMTP_STARTTLS=False
SMTP_SSL_TLS=True
SMTP_USE_CREDENTIALS=True
SMTP_VALIDATE_CERTS=True

ENV=development
RMS_ALLOW_DEFAULT_SECRET=1
REDIS_URL=redis://redis:6379/0

REDIS_PASSWORD=
TOTP_ISSUER=RMS
